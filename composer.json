{
    "name": "oddhill/drupal-starter-kit",
    "description": "Starter kit when creating a new site based on Drupal 8.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Christoffer Palm <christoffer.palm@oddhill.se>",
            "role": "Developer"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "7.4.6"
        }
    },
    "require": {
        "drupal/core": "^9.0.1",
        "drupal/core-project-message": "^9.0.0",
        "drupal/core-recommended": "^9.0.0",
        "oddhill/oddprofile": "^2.0",
        "vlucas/phpdotenv": "^5.2"
    },
    "require-dev": {
        "composer/composer": "^1.0",
        "composer/installers": "^1.7",
        "cweagans/composer-patches": "^1.0",
        "drupal/core-composer-scaffold": "^9.0.0",
        "drush/drush": "^10.3.0",
        "drupal/coder": "^8.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "OddDrupal\\": "scripts/odddrupal/"
        }
    },
    "scripts": {
        "drupal-scaffold": "DrupalComposer\\DrupalScaffold\\Plugin::scaffold",
        "key-generate": "OddDrupal\\KeyGenerator::generateAppKey",
        "create-files": "OddDrupal\\InstallationManager::createRequiredFiles",
        "post-create-project-cmd": [
            "OddDrupal\\InstallationManager::createRequiredFiles",
            "OddDrupal\\KeyGenerator::generateAppKey"
        ]
    },
    "extra": {
        "installer-paths": {
            "public/core": [
                "type:drupal-core"
            ],
            "public/libraries/{$name}": [
                "type:drupal-library"
            ],
            "public/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "public/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "public/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/contrib/{$name}": [
                "type:drupal-drush"
            ]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "public/"
            }
        }
    }
}
